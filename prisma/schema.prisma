// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["staff", "hr"]
}

model User {
  userId          Int              @id @default(autoincrement()) @map("user_id")
  email           String           @unique
  password        String
  role            Roles            @default(EMPLOYEE)
  permissions     Permissions[]    @default([USER_READ_SELF])
  status          Status           @default(INACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  address         Address?
  personalInfo    PersonalInfo?
  setting         Setting?
  employeeProfile EmployeeProfile?

  @@map("users")
  @@schema("staff")
}

model PersonalInfo {
  personalInfoId Int    @id @default(autoincrement()) @map("personal_info_id")
  firstName      String @map("first_name")
  lastName       String @map("last_name")
  phone          String
  user           User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userId         Int    @unique @map("user_id")

  @@map("personal_infos")
  @@schema("staff")
}

model Address {
  addressId  Int     @id @default(autoincrement()) @map("address_id")
  country    String
  city       String
  street     String
  postalCode String  @map("postal_code")
  buildingNo String? @map("building_no")
  localNo    String? @map("local_no")
  user       User    @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userId     Int     @unique @map("user_id")

  @@map("addresses")
  @@schema("staff")
}

model Setting {
  settingId Int      @id @default(autoincrement()) @map("setting_id")
  theme     Theme    @default(LIGHT)
  language  Language @default(EN)
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userId    Int      @unique @map("user_id")

  @@map("settings")
  @@schema("staff")
}

enum Roles {
  SUPERUSER
  ADMIN
  EMPLOYEE
  GUEST

  @@schema("staff")
}

enum Permissions {
  USER_READ_SELF
  USER_READ
  USER_CREATE
  USER_EDIT
  USER_DELETE
  USER_BLOCK
  USER_UNBLOCK

  @@schema("staff")
}

enum Status {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED

  @@schema("staff")
}

enum Theme {
  LIGHT
  DARK

  @@schema("staff")
}

enum Language {
  EN
  PL

  @@schema("staff")
}

model EmployeeProfile {
  employeeId Int  @id @default(autoincrement()) @map("employee_id")
  userId     Int  @unique @map("user_id")
  user       User @relation(fields: [userId], references: [userId])

  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  middleName    String?   @map("middle_name")
  preferredName String?   @map("preferred_name")
  dateOfBirth   DateTime? @map("date_of_birth")
  gender        String?
  nationality   String?
  maritalStatus String?   @map("marital_status")

  personalEmail                String? @map("personal_email")
  phoneNumber                  String? @map("phone_number")
  emergencyContactName         String? @map("emergency_contact_name")
  emergencyContactRelationship String? @map("emergency_contact_relationship")
  emergencyContactPhone        String? @map("emergency_contact_phone")

  hireDate         DateTime  @map("hire_date")
  employmentType   String    @map("employment_type")
  employmentStatus Status    @default(INACTIVE) @map("employment_status")
  probationEndDate DateTime? @map("probation_end_date")

  departmentId Int?        @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [departmentId])

  positionId Int?      @map("position_id")
  position   Position? @relation(fields: [positionId], references: [positionId])

  managerId        Int?              @map("manager_id")
  manager          EmployeeProfile?  @relation("manager_to_employee", fields: [managerId], references: [employeeId])
  managedEmployees EmployeeProfile[] @relation("manager_to_employee")

  baseSalary     Decimal? @map("base_salary")
  salaryCurrency Currency @default(PLN) @map("salary_currency")

  payGrade           PayGrade? @relation(fields: [payGradePayGradeId], references: [payGradeId])
  payGradePayGradeId Int?

  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  EmploymentHistory EmploymentHistory[]

  @@map("employee_profiles")
  @@schema("hr")
}

model Department {
  departmentId       Int     @id @default(autoincrement()) @map("department_id")
  departmentCode     String  @unique @map("department_code")
  departmentName     String  @map("department_name")
  parentDepartmentId Int?    @map("parent_department_id")
  departmentHeadId   Int?    @map("department_head_id")
  description        String?

  employees         EmployeeProfile[]
  positions         Position[]
  employmentHistory EmploymentHistory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("departments")
  @@schema("hr")
}

model Position {
  positionId    Int        @id @default(autoincrement()) @map("position_id")
  positionTitle String     @map("position_title")
  departmentId  Int        @map("department_id")
  department    Department @relation(fields: [departmentId], references: [departmentId])

  payGrade          PayGrade[]
  employees         EmployeeProfile[]
  employmentHistory EmploymentHistory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("positions")
  @@schema("hr")
}

model EmploymentHistory {
  historyId Int @id @default(autoincrement()) @map("history_id")

  employeeId Int             @map("employee_id")
  employee   EmployeeProfile @relation(fields: [employeeId], references: [employeeId])

  departmentId Int?        @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [departmentId])

  positionId Int?      @map("position_id")
  position   Position? @relation(fields: [positionId], references: [positionId])

  startDate DateTime  @map("start_date")
  endDate   DateTime? @map("end_date")

  reasonForChange String? @map("reason_for_change")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("employment_history")
  @@schema("hr")
}

model PayGrade {
  payGradeId Int @id @default(autoincrement()) @map("pay_grade_id")

  gradeCode String @unique @map("grade_code")
  gradeName String @map("grade_name")

  minSalary Decimal @map("min_salary")
  maxSalary Decimal @map("max_salary")

  description String?

  requiredExperience Int?    @map("required_experience")
  requiredEducation  String? @map("required_education")

  position           Position? @relation(fields: [positionPositionId], references: [positionId])
  positionPositionId Int?

  employeeProfile EmployeeProfile[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pay_grades")
  @@schema("hr")
}

enum Currency {
  PLN
  USD
  EUR
  GBP

  @@schema("hr")
}
